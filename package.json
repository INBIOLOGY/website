{
  "name": "inbiology",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"require('fs').cpSync('js','dist/js',{recursive:true});require('fs').cpSync('css','dist/css',{recursive:true})\"",
    "preview": "vite preview",
    "next:dev": "next dev --webpack",
    "next:build": "next build",
    "next:start": "next start",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "node --env-file-if-exists=.env.local scripts/migrate.mjs",
    "db:seed": "node --env-file-if-exists=.env.local scripts/seed.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.3",
    "lucide-react": "^1.25.0",
    "next": "latest",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}