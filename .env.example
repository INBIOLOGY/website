# Server-only values. Never expose these with the NEXT_PUBLIC_ prefix.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inbiology
SESSION_SECRET=replace-with-at-least-32-random-characters

# Provider integrations are intentionally unset until a vendor is selected.
PAYMENT_PROVIDER=
PAYMENT_WEBHOOK_SECRET=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
